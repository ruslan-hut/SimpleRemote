<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:id="@+id/document_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <ImageView
                android:id="@+id/document_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/document"
                app:tint="?attr/colorOnPrimaryContainer" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/document_title_receive"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/number_sign"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:id="@+id/document_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/holder_number"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/holder_number"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/document_header_contractor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contractor"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_contractor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/document_header_field1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <TextView
                android:id="@+id/document_field1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_field1_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/document_header_field2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <TextView
                android:id="@+id/document_field2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_field2_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/document_header_field3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <TextView
                android:id="@+id/document_field3_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_field3_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/document_header_field4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground">

            <TextView
                android:id="@+id/document_field4_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/document_field4_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/holder_text"
                android:textColor="?attr/colorOnBackground"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />
        </LinearLayout>

        <TextView
            android:id="@+id/document_header_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/android:colorBackground"
            android:hint="@string/notes">
        </TextView>

        <LinearLayout
            android:id="@+id/document_header_checked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:background="?attr/colorSurfaceVariant">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/checked"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/document_is_checked"
                android:layout_width="wrap_content"
                android:layout_height="24dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>