<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Keystroke Timeout -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:hint="@string/scanner_timeout_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/keystroke_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:inputType="number" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:text="@string/scanner_timeout_description" />

        <!-- Min Barcode Length -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:hint="@string/scanner_min_length_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/min_barcode_length"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:inputType="number" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:text="@string/scanner_min_length_description" />

        <!-- Terminator Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:paddingStart="16dp"
            android:text="@string/scanner_terminator_hint"
            android:textSize="14sp" />

        <RadioGroup
            android:id="@+id/terminator_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/terminator_both"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scanner_terminator_both" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/terminator_enter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Enter" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/terminator_tab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Tab" />

        </RadioGroup>

        <!-- Prefix to Strip -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:hint="@string/scanner_prefix_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/prefix_to_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:inputType="textNoSuggestions" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Suffix to Strip -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:hint="@string/scanner_suffix_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/suffix_to_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:inputType="textNoSuggestions" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:text="@string/scanner_prefix_suffix_description" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/test_scanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="@string/scanner_test_title" />

        <!-- Diagnostics section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:paddingStart="16dp"
            android:text="@string/diag_section_title"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:text="@string/diag_description" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/diag_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="@string/diag_toggle" />

        <TextView
            android:id="@+id/diag_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/diag_copy"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/diag_copy_clipboard" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/diag_upload"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/diag_upload_firebase" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
